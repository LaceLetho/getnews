# 加密货币新闻分析工具 - 环境变量模板
# 复制此文件为 .env 并填入实际配置值

# =============================================================================
# 共享配置
# =============================================================================

# PostgreSQL / pgvector（Railway 双服务共享）
# 当 storage.backend=postgres 时，DATABASE_URL 会覆盖 config.json 中的 storage.database_url
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# =============================================================================
# Analysis service / api-only
# =============================================================================

# LLM API 密钥（analysis-service 核心）
# 支持 OpenAI-compatible 提供方；未配置 KIMI_API_KEY 时走 LLM_API_KEY 路径
LLM_API_KEY=your_api_key_here

# 可选：市场快照依赖 Grok
GROK_API_KEY=your_grok_api_key_here

# 可选：若要显式使用 Kimi 路径则配置
KIMI_API_KEY=your_kimi_api_key_here

# API 鉴权（Railway 公网 analysis 服务 / --mode api-only 必需）
API_KEY=your_api_key_here

# Telegram Bot 配置（启用 Telegram 命令/投递时需要）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram channel ID：主要用于 legacy `once` / `schedule` 路径的报告投递
# 当前 split-service 生产路径中的 `ingestion` scheduler 不会定时发送分析报告
TELEGRAM_CHANNEL_ID=-1001234500123

# Telegram授权用户（启用 Telegram 命令入口时需要）
# 支持两种格式：
#   1. 用户ID（数字）: 123456789
#   2. 用户名（@开头）: @username
# 多个用户用逗号分隔，可以混合使用两种格式
# 
# 示例:
#   - 仅用户ID: 123456789,987654321
#   - 仅用户名: @user1,@user2,@user3
#   - 混合格式: 5844680524,@wingperp,@mcfangpy,@Huazero,@long0short
#
# 如何获取你的Telegram用户ID: 
#   1. 在Telegram中搜索 @userinfobot
#   2. 发送 /start 命令
#   3. Bot会返回你的用户ID
#
# 注意：使用用户名时，bot必须先与该用户互动过，或者用户有公开的profile
TELEGRAM_AUTHORIZED_USERS=your_user_id_here

# =============================================================================
# Ingestion service
# =============================================================================

# X/Twitter认证（按实际抓取源配置）
X_CT0=your_x_ct0_token_here
X_AUTH_TOKEN=your_x_auth_token_here

# =============================================================================
# 可选配置（有默认值）
# =============================================================================

# 时间窗口（小时）
TIME_WINDOW_HOURS=6

# 执行间隔（秒）- 用于定时调度模式
# 3600=1小时, 21600=6小时, 43200=12小时, 86400=24小时
EXECUTION_INTERVAL=21300

# 配置文件路径
CONFIG_PATH=./config.json

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# API 服务监听地址（`analysis-service` / `api-only`）
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# 使用说明
# =============================================================================
# 
# 本地开发:
#   1. 复制此文件为 .env
#   2. 填入实际的 API 密钥
#   3. 运行: uv run python -m crypto_news_analyzer.main --mode analysis-service
#
# Railway 部署:
#   - 不需要 .env 文件
#   - 直接在 Railway Dashboard 配置环境变量
#   - Railway 会自动使用项目根目录的 Dockerfile 构建镜像
#
