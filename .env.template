# 加密货币新闻分析工具 - 环境变量模板（split-service）
# 复制此文件为 .env，并只填写与你运行模式对应的配置
# 支持的运行模式：analysis-service、api-only、ingestion

# =============================================================================
# 共享配置（所有服务）
# =============================================================================

# PostgreSQL / pgvector（split-service 共享存储）
# 当 storage.backend=postgres 时，必须通过环境变量提供 DATABASE_URL
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# 配置文件路径
CONFIG_PATH=./config.jsonc

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# analysis-service / api-only
# =============================================================================

# API 鉴权（启用 analysis-service / api-only 时必需）
API_KEY=your_api_key_here

# API 服务监听地址（`analysis-service` / `api-only`）
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# analysis-service 额外需要
# =============================================================================

# LLM Provider 凭证（analysis-service 执行分析时必需）
# 使用 provider-specific 环境变量而非通用 LLM_API_KEY
# 支持的 provider：kimi（使用 KIMI_API_KEY），grok（使用 GROK_API_KEY），opencode-go（使用 OPENCODE_API_KEY）
# 具体模型和配置在 config.jsonc 的 llm_config 中定义
KIMI_API_KEY=your_kimi_api_key_here
GROK_API_KEY=your_grok_api_key_here
OPENCODE_API_KEY=your_opencode_api_key_here

# 语义搜索 Embedding（启用 semantic_search 时必需）
# 当前实现使用 OpenAI text-embedding-3-small 生成 1536 维向量
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot（analysis-service 启用命令监听时必需）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234500123

# Telegram 授权用户
# 支持两种格式：
#   1. 用户ID（数字）: 123456789
#   2. 用户名（@开头）: @username
# 多个用户用逗号分隔，可以混合使用两种格式
# 示例: 123456789,@user1,987654321,@user2
TELEGRAM_AUTHORIZED_USERS=your_user_id_here

# =============================================================================
# ingestion
# =============================================================================

# 执行间隔（秒）
# 3600=1小时, 21600=6小时, 43200=12小时, 86400=24小时
EXECUTION_INTERVAL=21300

# 时间窗口（小时）
TIME_WINDOW_HOURS=6

# X/Twitter 认证（启用对应抓取源时必需）
X_CT0=your_x_ct0_token_here
X_AUTH_TOKEN=your_x_auth_token_here

# Bird 抓取器（可选；未设置时使用内置默认值）
# BIRD_EXECUTABLE_PATH=bird
# BIRD_TIMEOUT_SECONDS=300
# BIRD_MAX_RETRIES=3
# BIRD_OUTPUT_FORMAT=json
# BIRD_RATE_LIMIT_DELAY=1.0
# BIRD_CONFIG_PATH=~/.bird/config.json
# BIRD_ENABLE_AUTO_RETRY=true
# BIRD_RETRY_DELAY_SECONDS=60
# BIRD_MAX_PAGE=3

# =============================================================================
# Intelligence Collection（可选 — 需要添加 telegram_group / v2ex 数据源后生效）
# =============================================================================
# 配置说明：以下环境变量仅 intelligence collection 使用。
# 不设置时，其他模式不受影响。
# 添加 telegram_group 数据源前，需要先配置 Telethon API 凭证。
# 添加 v2ex 数据源前，需要先获取 V2EX 的 Personal Access Token。

# Telethon API 凭证（用于 Telegram 群组情报采集 — 可选）
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_STRING_SESSION=

# V2EX API（用于 V2EX 情报采集 — 可选）
# V2EX_PAT=
# =============================================================================
# 使用说明
# =============================================================================
# 本地开发:
#   1. 复制此文件为 .env
#   2. 按目标运行模式填写对应分区
#   3. 运行 retained modes 之一：
#      uv run python -m crypto_news_analyzer.main --mode analysis-service
#      uv run python -m crypto_news_analyzer.main --mode api-only
#      uv run python -m crypto_news_analyzer.main --mode ingestion
#
# Railway 部署:
#   - 为 `crypto-news-analysis` 与 `crypto-news-ingestion` 分别配置环境变量
#   - 两个服务共用同一个 DATABASE_URL
#   - 只给 analysis 服务配置 API/LLM/Telegram 相关变量
