# 加密货币新闻分析工具 - 环境变量模板（split-service）
# 复制此文件为 .env，并只填写与你运行模式对应的配置
# 支持的运行模式：analysis-service、api-only、ingestion

# =============================================================================
# 共享配置（所有服务）
# =============================================================================

# PostgreSQL / pgvector（split-service 共享存储）
# 当 storage.backend=postgres 时，DATABASE_URL 会覆盖 config.json 中的 storage.database_url
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# 配置文件路径
CONFIG_PATH=./config.json

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# analysis-service / api-only
# =============================================================================

# API 鉴权（启用 analysis-service / api-only 时必需）
API_KEY=your_api_key_here

# API 服务监听地址（`analysis-service` / `api-only`）
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# analysis-service 额外需要
# =============================================================================

# LLM API密钥（analysis-service 执行分析时必需）
# 支持 xAI Grok, OpenAI GPT, MiniMax, Kimi 等兼容 OpenAI API 的服务
LLM_API_KEY=your_api_key_here
GROK_API_KEY=your_grok_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# Telegram Bot（analysis-service 启用命令监听时必需）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234500123

# Telegram 授权用户
# 支持两种格式：
#   1. 用户ID（数字）: 123456789
#   2. 用户名（@开头）: @username
# 多个用户用逗号分隔，可以混合使用两种格式
# 示例: 123456789,@user1,987654321,@user2
TELEGRAM_AUTHORIZED_USERS=your_user_id_here

# =============================================================================
# ingestion
# =============================================================================

# 执行间隔（秒）
# 3600=1小时, 21600=6小时, 43200=12小时, 86400=24小时
EXECUTION_INTERVAL=21300

# 时间窗口（小时）
TIME_WINDOW_HOURS=6

# X/Twitter 认证（启用对应抓取源时必需）
X_CT0=your_x_ct0_token_here
X_AUTH_TOKEN=your_x_auth_token_here

# =============================================================================
# 使用说明
# =============================================================================
# 本地开发:
#   1. 复制此文件为 .env
#   2. 按目标运行模式填写对应分区
#   3. 运行 retained modes 之一：
#      uv run python -m crypto_news_analyzer.main --mode analysis-service
#      uv run python -m crypto_news_analyzer.main --mode api-only
#      uv run python -m crypto_news_analyzer.main --mode ingestion
#
# Railway 部署:
#   - 为 `crypto-news-analysis` 与 `crypto-news-ingestion` 分别配置环境变量
#   - 两个服务共用同一个 DATABASE_URL
#   - 只给 analysis 服务配置 API/LLM/Telegram 相关变量
